# =============================================================================
# RiskRadar — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The backend loads these via pydantic-settings (see backend/config/settings.py).
# The .env file should be in the project root (same level as backend/ folder).
# =============================================================================

# --- JWT Authentication (REQUIRED) -----------------------------------------
# Secret key for signing JWT tokens. Generate a random one:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-generate-a-random-secret

# Token lifetime in minutes (default: 60)
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---------------------------------------------------------------
# For local development, SQLite is used automatically (no config needed).
# For production, set a MySQL/MariaDB connection string:
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/riskradar

# --- LLM (REQUIRED for summary generation) ---------------------------------
# Provider: "deepseek", "openai", or "anthropic"
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-llm-api-key-here

# --- Scraper API Keys -------------------------------------------------------
# AirNow — free key from https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=your-airnow-key

# NASA FIRMS — key from https://firms.modaps.eosdis.nasa.gov/api/area/
# NASA_FIRMS_MAP_KEY=your-nasa-key

# Firecrawl — key from https://firecrawl.dev (for web scraping sources)
# FIRECRAWL_API_KEY=your-firecrawl-key

# --- App Defaults -----------------------------------------------------------
# DEFAULT_ZIP_CODE=90001
# DEFAULT_LAT=34.0522
# DEFAULT_LON=-118.2437
# SCRAPE_INTERVAL_MINUTES=30
